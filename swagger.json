{
  "openapi": "3.0.0",
  "info": {
    "title": "ERP Grupo Du API",
    "description": "API para ERP do Grupo Du",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "https://gcp-backend-gnxf.onrender.com",
      "description": "Servidor de Produção"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token",
        "description": "Autenticação via cookie HttpOnly contendo o token JWT"
      }
    },
    "schemas": {
      "Response": {
        "type": "object",
        "properties": {
          "data": { "type": "object" },
          "status": { "type": "integer" },
          "message": { "type": "string" },
          "success": { "type": "boolean" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "senha", "user_type"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "senha": { "type": "string", "format": "password" },
          "user_type": { "type": "string" }
        }
      },
      "Goal": {
        "type": "object",
        "required": ["goal_id", "goal_title", "goal_type", "goal_deadline"],
        "properties": {
          "goal_id": { "type": "string", "format": "uuid" },
          "goal_title": { "type": "string" },
          "goal_description": { "type": "string", "nullable": true },
          "goal_type": { "type": "string" },
          "goal_deadline": { "type": "string", "format": "date-time" },
          "employee_goal": {
            "type": "string",
            "nullable": true,
            "format": "uuid"
          },
          "goal_status": { "type": "string" }
        }
      },
      "User": {
        "type": "object",
        "required": ["user_id", "name", "email", "password", "user_type"],
        "properties": {
          "user_id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password" },
          "user_type": { "type": "string" }
        }
      },
      "Product": {
        "type": "object",
        "required": ["uuid", "name", "description", "product_type", "image"],
        "properties": {
          "uuid": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "product_type": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "image": { "type": "string" },
          "features": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acronym": { "type": "string", "nullable": true },
          "composition": {
            "type": "object",
            "description": "Campo JSON flexível"
          },
          "stock_quantity": {
            "type": "integer"
          }
        }
      },
      "Employee": {
        "type": "object",
        "required": ["name", "employee_type"],
        "properties": {
          "employee_uuid": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "employee_type": { "type": "string" }
        }
      },
      "Feedback": {
        "type": "object",
        "required": ["card_name", "card_description"],
        "properties": {
          "card_name": { "type": "string" },
          "card_description": { "type": "string" }
        }
      },
      "ProductionOrder": {
        "type": "object",
        "required": [
          "production_order_id",
          "production_order_title",
          "production_order_deadline",
          "delivered_product_quantity"
        ],
        "properties": {
          "production_order_id": { "type": "string", "format": "uuid" },
          "production_order_title": { "type": "string" },
          "production_order_description": {
            "type": "string",
            "nullable": true
          },
          "production_order_deadline": {
            "type": "string",
            "format": "date-time"
          },
          "delivery_observation": { "type": "string", "nullable": true },
          "delivered_product_quantity": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "stock_validation": { "type": "boolean" },
          "delivered_at": { "type": "string", "format": "date-time" },
          "cut_assistant": {
            "type": "string",
            "nullable": true,
            "format": "uuid"
          },
          "fold_assistant": {
            "type": "string",
            "nullable": true,
            "format": "uuid"
          },
          "finishing_assistant": {
            "type": "string",
            "nullable": true,
            "format": "uuid"
          },
          "paint_assistant": {
            "type": "string",
            "nullable": true,
            "format": "uuid"
          },
          "employee_uuid": {
            "type": "string",
            "nullable": true,
            "format": "uuid"
          },
          "supervisor_uuid": { "type": "string", "format": "uuid" }
        }
      },
      "Order": {
        "required": ["order_id", "order_title", "order_deadline"],
        "properties": {
          "order_id": { "type": "string", "format": "uuid" },
          "order_title": { "type": "string" },
          "order_deadline": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" },
          "order_status": { "type": "string" },
          "order_description": { "type": "string", "nullable": true },
          "delivery_observation": { "type": "string", "nullable": true }
        }
      },
      "OrderItem": {
        "required": [
          "order_item_id",
          "order_id",
          "product_id",
          "quantity",
          "unit_price"
        ],
        "properties": {
          "order_item_id": { "type": "string", "format": "uuid" },
          "order_id": { "type": "string", "format": "uuid" },
          "product_id": { "type": "string", "format": "uuid" },
          "quantity": { "type": "integer" },
          "unit_price": { "type": "number", "format": "double" }
        }
      },
      "DeliveryOrder": {
        "type": "object",
        "required": [
          "delivered_product_quantity",
          "requested_product_quantity"
        ],
        "properties": {
          "delivered_product_quantity": { "type": "number" },
          "requested_product_quantity": { "type": "number" }
        }
      },
      "AssistantsPORegisters": {
        "type": "object",
        "required": [
          "assistants_po_registers_uuid",
          "delivered",
          "production_order_uuid",
          "assistant_uuid",
          "assistant_as"
        ],
        "properties": {
          "assistants_po_registers_uuid": {
            "type": "string",
            "format": "uuid"
          },
          "delivered": { "type": "boolean" },
          "delivered_at": { "type": "string", "format": "date-time" },
          "production_order_uuid": { "type": "string", "format": "uuid" },
          "assistant_uuid": { "type": "string", "format": "uuid" },
          "assistant_as": { "type": "string" }
        }
      },
      "DeliverProductionOrder": {
        "type": "object",
        "required": [
          "delivered_product_quantity",
          "requested_product_quantity"
        ],
        "properties": {
          "delivered_product_quantity": { "type": "number" },
          "requested_product_quantity": { "type": "number" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": { "type": "integer" },
          "message": { "type": "string" },
          "success": { "type": "boolean" },
          "error": { "type": "string" }
        },
        "example": {
          "status": 500,
          "message": "Erro interno do servidor.",
          "success": false,
          "error": "Erro interno do servidor."
        }
      }
    }
  },
  "security": [{ "cookieAuth": [] }],
  "paths": {
    "/login": {
      "post": {
        "summary": "Realiza login do usuário",
        "tags": ["Login"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" },
              "example": {
                "email": "usuario@grupodu.com",
                "senha": "123456",
                "user_type": "admin"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "content": {
              "application/json": {
                "example": {
                  "data": {
                    "user": {
                      "user_id": "6aaf3e59-6d26-40d8-94ef-36e468af493d",
                      "user_type": "admin"
                    }
                  },
                  "status": 200,
                  "message": "Login realizado com sucesso",
                  "success": true
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas",
            "content": {
              "application/json": {
                "example": {
                  "status": 401,
                  "message": "Credenciais inválidas. Verifique suas credenciais e tente novamente.",
                  "success": false,
                  "error": "Credenciais inválidas"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/login/refresh": {
      "post": {
        "summary": "Renova o token de acesso",
        "tags": ["Login"],
        "responses": {
          "200": {
            "description": "Token renovado com sucesso",
            "content": {
              "application/json": {
                "example": {
                  "data": null,
                  "status": 200,
                  "message": "Token renovado com sucesso",
                  "success": true
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado",
            "content": {
              "application/json": {
                "examples": {
                  "RefreshTokenNotProvided": {
                    "value": {
                      "error": "Refresh token não fornecido.",
                      "status": 401,
                      "message": "Refresh token não fornecido.",
                      "success": false
                    }
                  },
                  "FailedToRefresh": {
                    "value": {
                      "error": "Falha ao renovar token.",
                      "status": 401,
                      "message": "Refresh token não fornecido.",
                      "success": false
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/login/verify": {
      "get": {
        "summary": "Verifica se o token é válido",
        "tags": ["Login"],
        "responses": {
          "200": {
            "description": "Token válido"
          },
          "401": {
            "description": "Token inválido"
          }
        }
      }
    },
    "/login/logout": {
      "post": {
        "summary": "Realiza logout do usuário",
        "tags": ["Login"],
        "responses": {
          "200": {
            "description": "Logout realizado com sucesso"
          }
        }
      }
    },
    "/goals": {
      "get": {
        "summary": "Lista todas as metas",
        "tags": ["Goals"],
        "responses": {
          "200": {
            "description": "Lista de metas retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Goal" }
                }
              }
