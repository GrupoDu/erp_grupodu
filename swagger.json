          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      },
      "post": {
        "summary": "Cria uma nova meta (Apenas Admin)",
        "tags": ["Goals"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
