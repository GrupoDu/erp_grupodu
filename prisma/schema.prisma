generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  user_id   String @id(map: "users_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  email     String
  password  String
  user_type String
}

model produtos {
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  name         String   @unique(map: "produtos_nome_key")
  description  String
  product_type String
  image        String
  features     String[]
  acronym      String?
  composition  Json?
  uuid         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
}
